# The Boy Assistant - 环境变量配置
# 复制为 .env 后填入实际值

# Database
DATABASE_URL=postgresql+asyncpg://the_boy:the_boy_dev@localhost:5432/the_boy

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GLM_API_KEY=your_glm_api_key
CLAUDE_API_KEY=your_claude_api_key

# Encryption
ENCRYPTION_KEY=your_fernet_encryption_key

# Workspace
WORKSPACE_BASE_PATH=/tmp/the-boy/workspaces

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
