# The Boy Assistant - 环境变量配置
# 复制为 .env 后填入实际值

# Database
DATABASE_URL=postgresql+asyncpg://the_boy:the_boy_dev@localhost:5432/the_boy

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GLM_API_KEY=your_glm_api_key
CLAUDE_API_KEY=your_claude_api_key

# Encryption
ENCRYPTION_KEY=your_fernet_encryption_key

# ── LangFuse 可观测性 ──
# 启动 LangFuse: docker compose -f ../docker-compose.langfuse.yml up -d
# 访问 Dashboard: http://localhost:3000
# API Keys 在 Dashboard → Settings → API Keys 中获取
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── 告警 Webhook（可选）──
# Slack: 在 https://api.slack.com/apps → Incoming Webhooks 获取
# Discord: 在服务器设置 → 集成 → Webhooks 获取
# 不配置则跳过告警
ALERT_WEBHOOK_SLACK=
ALERT_WEBHOOK_DISCORD=
ALERT_WEBHOOK_CUSTOM=
ALERT_LEVEL=warning

# Workspace
WORKSPACE_BASE_PATH=/tmp/the-boy/workspaces

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
